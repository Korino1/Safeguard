{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/bin/windows/safeguard-hook.exe\"",
            "timeout": 10,
            "statusMessage": "Safeguard checking edit policy"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/bin/windows/safeguard-hook.exe\"",
            "timeout": 10,
            "statusMessage": "Safeguard checking permission policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/bin/windows/safeguard-hook.exe\"",
            "timeout": 10,
            "statusMessage": "Safeguard auditing edit"
          }
        ]
      }
    ]
  }
}
